# Entorno
APP_ENV=production
DEBUG=false
APP_NAME=QR Attendance System

# Red
APP_HOST=app.tu-dominio.com
TRAEFIK_NETWORK=coolify
TRAEFIK_CERTRESOLVER=letsencrypt
BASE_URL=https://app.tu-dominio.com
CORS_ORIGINS=https://app.tu-dominio.com,https://tu-dominio.com
ALLOWED_HOSTS=app.tu-dominio.com,tu-dominio.com
LANDING_WHATSAPP_URL=https://wa.me/?text=Hola%20quiero%20una%20demo%20del%20sistema

# Seguridad
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MASTER_BOOTSTRAP_KEY=replace-bootstrap-key
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=tu-usuario
SMTP_PASSWORD=tu-password
SMTP_FROM_EMAIL=no-reply@tu-dominio.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
N8N_WEBHOOK_ENABLED=false
N8N_WEBHOOK_URL=https://n8n.tu-dominio.com/webhook/attendance-events
N8N_WEBHOOK_TIMEOUT_SECONDS=8

# Base de datos
DATABASE_URL=postgresql+asyncpg://postgres:replace-db-password@db.tu-proveedor.com:5432/postgres?ssl=require

# Operacion
LOG_LEVEL=INFO
WORKERS=2
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
